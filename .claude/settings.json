{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpm dlx prettier --write"
          }
        ]
      },
      {
        "matcher": "Edit:*.astro|Edit:*.ts",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm astro check"
          }
        ]
      }
    ]
  }
}
