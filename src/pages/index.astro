---
import Layout from '../layouts/Layout.astro';
import Hero from '@components/homepage/Hero.astro';
import About from '@components/homepage/About.astro';
import Skills from '@components/homepage/Skills.astro';
import Experience from '@components/homepage/Experience.astro';
import BlogPreview from '@components/homepage/BlogPreview.astro';
import Contact from '@components/homepage/Contact.astro';

const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  dateCreated: '2026-03-01T00:00:00+01:00',
  dateModified: new Date().toISOString(),
  mainEntity: {
    '@type': 'Person',
    '@id': 'https://www.monfort.pro/#person',
    name: 'Stéphane Monfort',
    jobTitle: 'CTO & Architecte Cloud Senior Freelance',
    url: 'https://www.monfort.pro',
    email: 'stephane@monfort.pro',
    sameAs: ['https://www.linkedin.com/in/smonfort'],
    knowsAbout: [
      'Cloud Architecture',
      'AWS',
      'Kubernetes',
      'Tech Leadership',
      'DevOps',
      'Software Architecture',
    ],
    hasCredential: [
      {
        '@type': 'EducationalOccupationalCredential',
        name: 'AWS Certified Solutions Architect – Associate',
        credentialCategory: 'Professional Certification',
        recognizedBy: { '@type': 'Organization', name: 'Amazon Web Services' },
      },
      {
        '@type': 'EducationalOccupationalCredential',
        name: 'TOGAF 9.1 Expert',
        credentialCategory: 'Professional Certification',
        recognizedBy: { '@type': 'Organization', name: 'The Open Group' },
      },
    ],
    alumniOf: {
      '@type': 'CollegeOrUniversity',
      name: 'École Centrale de Lyon',
    },
  },
});
---

<Layout
  title="Stéphane Monfort — CTO & Architecte Cloud Senior Freelance"
  description="CTO et Architecte Cloud Senior freelance, certifié AWS et TOGAF. 18 ans d'expérience en architecture de solutions et tech leadership."
>
  <Fragment slot="head" set:html={`<script type="application/ld+json">${personSchema}</script>`} />
  <Hero />
  <About />
  <Skills />
  <Experience />
  <BlogPreview />
  <Contact />
</Layout>
