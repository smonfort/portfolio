---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const expertises = [
  {
    category: 'Leadership & Stratégie',
    items: [
      { name: 'Tech leadership', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />' },
      { name: 'Architecture de solutions', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />' },
      { name: 'Orientation business', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />' },
      { name: 'Agilité', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />' },
      { name: 'Design thinking', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />' },
      { name: 'Conseil IT', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />' },
      { name: 'Recrutement', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />' },
      { name: 'Mentoring', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />' },
    ],
  },
  {
    category: 'Cloud & Infrastructure',
    items: [
      { name: 'AWS', iconUrl: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-plain-wordmark.svg' },
      { name: 'Docker', icon: 'docker' },
      { name: 'Kubernetes', icon: 'kubernetes' },
      { name: 'Terraform', icon: 'terraform' },
      { name: 'Pulumi', icon: 'pulumi' },
      { name: 'Lambda', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5h2l3 6-5 8h3l3.5-5.5L14 19h3L9 5H4z" />' },
      { name: 'EKS', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />' },
      { name: 'EC2', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12H3m2 0a9 9 0 1018 0 9 9 0 00-18 0zm7-9v2m0 14v2m7-9h2M3 12h2m12.364-6.364l-1.414 1.414M7.05 16.95l-1.414 1.414M18.364 18.364l-1.414-1.414M7.05 7.05L5.636 5.636" />' },
      { name: 'ECS', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />' },
      { name: 'Step Functions', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />' },
      { name: 'RDS', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7c0-1.657 3.582-3 8-3s8 1.343 8 3v2c0 1.657-3.582 3-8 3s-8-1.343-8-3V7zm0 5c0 1.657 3.582 3 8 3s8-1.343 8-3m-16 5c0 1.657 3.582 3 8 3s8-1.343 8-3v-5" />' },
      { name: 'S3', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />' },
      { name: 'SQS', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 4H6a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-2m-4-1v8m0 0l-3-3m3 3l3-3" />' },
      { name: 'Landing zone', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />' },
      { name: 'FinOps', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />' },
    ],
  },
  {
    category: 'CI/CD & Qualité',
    items: [
      { name: 'GitLab CI', icon: 'gitlab' },
      { name: 'Argo CD', icon: 'argo' },
      { name: 'Helm', icon: 'helm' },
      { name: 'SonarQube', iconUrl: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/sonarqube/sonarqube-original.svg' },
      { name: 'Harbor', icon: 'harbor' },
      { name: 'Renovate', icon: 'renovate' },
      { name: 'n8n', icon: 'n8n' },
      { name: 'Dependency-Track', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />' },
    ],
  },
  {
    category: 'Frontend',
    items: [
      { name: 'React', icon: 'react' },
      { name: 'Next.js', icon: 'nextdotjs' },
      { name: 'Vue.js', icon: 'vuedotjs' },
      { name: 'Nuxt', iconUrl: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nuxtjs/nuxtjs-original.svg' },
      { name: 'Astro', icon: 'astro' },
      { name: 'Tailwind CSS', icon: 'tailwindcss' },
    ],
  },
  {
    category: 'Backend',
    items: [
      { name: 'Spring Boot', icon: 'spring' },
      { name: 'Node.js', icon: 'nodedotjs' },
      { name: 'NestJS', icon: 'nestjs' },
      { name: 'GraphQL', icon: 'graphql' },
      { name: 'REST API', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />' },
      { name: 'tRPC', icon: 'trpc' },
      { name: 'Go', icon: 'go' },
      { name: 'Keycloak', icon: 'keycloak' },
    ],
  },
  {
    category: 'Data & IA',
    items: [
      { name: 'PostgreSQL', icon: 'postgresql' },
      { name: 'MongoDB', icon: 'mongodb' },
      { name: 'Kafka', icon: 'apachekafka' },
      { name: 'ElasticSearch', icon: 'elasticsearch' },
      { name: 'Redis', iconUrl: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/redis/redis-original.svg' },
      { name: 'DynamoDB', iconUrl: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/dynamodb/dynamodb-original.svg' },
      { name: 'DatoCMS', icon: 'datocms' },
      { name: 'Athena', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />' },
      { name: 'Bedrock', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />' },
      { name: 'GitHub Copilot', icon: 'githubcopilot' },
      { name: 'Claude Code', icon: 'anthropic' },
    ],
  },
  {
    category: 'Tooling',
    items: [
      { name: 'Git', icon: 'git' },
      { name: 'Lazygit', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />' },
      { name: 'GitHub', icon: 'github' },
      { name: 'GitLab', icon: 'gitlab' },
      { name: 'Jira', icon: 'jira' },
      { name: 'Confluence', icon: 'confluence' },
      { name: 'Notion', icon: 'notion' },
      { name: 'Neovim', icon: 'neovim' },
      { name: 'Tmux', icon: 'tmux' },
      { name: 'k9s', svg: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18" />' },
      { name: 'Bruno', icon: 'bruno' },
    ],
  },
];

const certifications = [
  { name: 'AWS Certified Solutions Architect – Associate', issuer: 'Amazon Web Services', icon: '☁️', link: 'https://www.credly.com/badges/aa0dde9d-3422-4f16-8be8-352c315a5328/linked_in_profile' },
  { name: 'TOGAF 9.1 Expert', issuer: 'The Open Group', icon: '🏛️', link: null },
];

const experiences = [
  {
    title: 'Chief Technical Officer',
    company: 'Crédit Agricole Conseil et Développement Digital',
    logo: { type: 'icon', url: '/logos/cacd2.png' },
    period: '2018 – 2026',
    bullets: [
      'Membre fondateur du comité de direction de la digital factory du Groupe Crédit Agricole S.A.',
      'Direction du département Technologies : 40 ETP (architectes, développeurs front/back/mobile, QA, DevOps, cybersécurité).',
      'Définition et mise en œuvre de la stratégie cloud public AWS/Azure : landing zone privative, infrastructure-as-code à l\'échelle en Terraform.',
      'Conception d\'architectures cloud native pour Sofinco, LCL, CAA, CASA, CA-Titres, CA-PS, CAL&F, CATE.',
      'Développement business : avant-vente, cadrage, due diligences — 11,3M€ de CA en 2024.',
    ],
    tags: ['Tech management', 'Architecture', 'AWS', 'Kubernetes', 'Cloud Native', 'DevSecOps'],
  },
  {
    title: 'Architecte SI — Manager',
    company: 'Sopra-Stéria',
    logo: { type: 'icon', url: '/logos/sopra-steria.png' },
    period: '2014 – 2018',
    bullets: [
      'Manager au sein de la Business Unit Secteur Public.',
      'Lead architecte Sopra-Stéria pour la Direction Générale des Finances Publiques.',
      'Conception from scratch du prélèvement à la source et de la Déclaration Sociale Nominative.',
      'Amélioration continue de la télédéclaration de l\'impôt sur le revenu, en charge du chantier performance.',
    ],
    tags: ['Architecture SI', 'Secteur Public', 'Performance', 'Open Source'],
  },
  {
    title: 'Architecte SI',
    company: 'IBM Global Business Services',
    logo: { type: 'icon', url: '/logos/ibm.png' },
    period: '2008 – 2014',
    bullets: [
      'Développeur fullstack puis architecte logiciel au sein de la Division Application Innovation Services d\'IBM GBS France.',
      'Projets de build internationaux dans l\'énergie, les médias et la défense.',
      'Expertise en sécurisation d\'architecture SOA et appliance IBM DataPower.',
      'Graduate Program EMEA — formations internationales sur 12 mois.',
    ],
    tags: ['SOA', 'IBM DataPower', 'Architecture logicielle', 'Dev fullstack'],
  },
];
---

<Layout
  title="Stéphane Monfort — CTO & Architecte Cloud Senior Freelance"
  description="CTO et Architecte Cloud Senior freelance, certifié AWS et TOGAF. 18 ans d'expérience en architecture de solutions et tech leadership."
>
  <!-- Hero -->
  <section class="min-h-screen flex items-center justify-center px-6 pt-16">
    <div class="max-w-3xl text-center">
      <div class="inline-flex items-center gap-2 text-sm text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-4 py-1.5 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400 transition-colors duration-1000"></span>
        </span>
        Disponible pour de nouvelles missions 👋
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold text-white leading-tight mb-4">
        <span id="typewriter"></span><span id="cursor" class="inline-block w-[3px] h-[0.85em] bg-white align-middle ml-1"></span>
        <style>@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } } .blink { animation: blink 1s step-end infinite; }</style>
      </h1>
      <p class="text-2xl sm:text-3xl font-semibold mb-6">
        <span class="text-gradient">CTO & architecte cloud senior</span>
      </p>
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-4">
        18 ans d'expérience en architecture de systèmes complexes et leadership d'équipes techniques.
        Je vous accompagne pour structurer votre SI, accélérer votre migration cloud
        et faire grandir vos équipes.
      </p>
<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#experience"
          class="w-full sm:w-auto px-8 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-xl transition-colors text-sm"
        >
          Mon parcours
        </a>
        <a
          href="#contact"
          class="w-full sm:w-auto px-8 py-3.5 bg-white/5 hover:bg-white/10 text-white font-medium rounded-xl border border-white/10 transition-colors text-sm"
        >
          Me contacter
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">À propos</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-8 leading-tight">
            Une expertise tech de bout de bout, de la stratégie IT au delivery produit
          </h2>
          <div class="space-y-5 text-gray-400 leading-relaxed">
            <p>
            J'ai construit mon expertise sur ces 18 dernières années, d'architecte logiciel chez IBM
              à membre du comité de direction de CACD2, la digital factory du Groupe Crédit Agricole SA, où j'ai exercé les fonctions de CTO pendant 7 ans.
            </p>
            <p>
              Ce qui me différencie : un <span class="text-white font-medium">large spectre d'intervention</span>.
              <span class="text-white font-medium">Hands-on</span> si nécessaire, je peux définir et mettre en oeuvre des architectures complexes,
              challenger les choix techniques et co-concevoir une solution avec les équipes.
              Je dispose également d'une <span class="text-white font-medium">vision stratégique</span> affirmée en veillant à 
              aligner la technologie sur les enjeux business.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 md:pt-16">
          {[
            { value: '18+', emoji: '🗓️', label: 'années d\'expérience' },
            { value: '45+', emoji: '👥', label: 'ETP managés' },
            { value: '8+',  emoji: '☁️', label: 'années d\'expérience sur AWS' },
            { value: '2',   emoji: '🏆', label: 'certifications' },
            { value: '50+', emoji: '🚀', label: 'projets livrés' },
            { value: '100%',emoji: '🔥', label: 'passionné' },
          ].map(({ value, emoji, label }) => (
            <div class="bg-white/[0.03] border border-white/5 rounded-2xl p-6 text-center hover:border-indigo-500/20 transition-colors">
              <div class="text-2xl font-bold text-gradient mb-1">{value}</div>
              <div class="text-sm text-gray-300">{label} {emoji}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Expertises -->
  <section id="skills" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Expertise</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Mes principaux domaines d'expertise</h2>
      </div>
      <div class="divide-y divide-white/5">
        {expertises.map(({ category, items }) => (
          <div class="py-8 grid md:grid-cols-4 gap-6 items-start">
            <h3 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider md:pt-1">{category}</h3>
            <div class="md:col-span-3 flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1.5 rounded-lg bg-white/5 border border-white/5 text-gray-300">
                  {item.icon && (
                    <img
                      src={`https://cdn.simpleicons.org/${item.icon}/a5b4fc`}
                      alt={item.name}
                      class="w-3.5 h-3.5 flex-shrink-0"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  )}
                  {item.iconUrl && (
                    <img
                      src={item.iconUrl}
                      alt={item.name}
                      class="w-3.5 h-3.5 flex-shrink-0"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  )}
                  {item.svg && (
                    <svg class="w-3.5 h-3.5 flex-shrink-0 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.svg} />
                  )}
                  {!item.icon && !item.iconUrl && !item.svg && <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>}
                  {item.name}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Certifications -->
      <div class="text-center mt-20 mb-16">
        <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Certifications</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Certifications professionnelles</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {certifications.map(({ name, issuer, icon, link }) => (
          link ? (
            <a href={link} target="_blank" rel="noopener" class="flex items-center gap-4 bg-white/[0.03] border border-white/5 rounded-2xl p-5 hover:border-amber-500/30 transition-colors group">
              <span class="text-2xl">{icon}</span>
              <div class="flex-1">
                <p class="text-sm font-semibold text-white group-hover:text-amber-400 transition-colors">{name}</p>
              </div>
              <svg class="w-4 h-4 text-gray-600 group-hover:text-amber-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ) : (
            <div class="flex items-center gap-4 bg-white/[0.03] border border-white/5 rounded-2xl p-5 hover:border-indigo-500/30 transition-colors">
              <span class="text-2xl">{icon}</span>
              <div>
                <p class="text-sm font-semibold text-white">{name}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- Expériences -->
  <section id="experience" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Références</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Expériences professionnelles</h2>
      </div>
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-white/5 hidden md:block -translate-x-px"></div>

        <div class="space-y-8">
          {experiences.map((exp, i) => (
            <div class:list={['group relative md:grid md:grid-cols-2 gap-8 items-start', i % 2 === 0 ? '' : 'md:[&>article]:col-start-2']}>
              <!-- Dot -->
              <div class="hidden md:block absolute left-1/2 top-6 w-3 h-3 rounded-full bg-indigo-500 border-2 border-indigo-900 -translate-x-1.5 z-10 group-hover:scale-125 transition-transform"></div>

              <article class:list={['bg-white/[0.03] border border-white/5 rounded-2xl p-6 hover:border-indigo-500/30 transition-colors', i % 2 !== 0 ? 'md:col-start-2' : '']}>
                <div class="flex items-start justify-between gap-4 mb-3">
                  <div class="flex items-center gap-3">
                    {exp.logo.type === 'initials' && (
                      <div class:list={['w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 text-xs font-bold text-white', exp.logo.bg]}>
                        {exp.logo.text}
                      </div>
                    )}
                    {exp.logo.type === 'icon' && (
                      <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
                        <img src={exp.logo.url} alt={exp.company} class="w-8 h-8 object-contain" loading="lazy" />
                      </div>
                    )}
                    <div>
                      <h3 class="text-base font-semibold text-white">{exp.title}</h3>
                      <p class="text-sm text-indigo-400">{exp.company}</p>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 whitespace-nowrap">{exp.period}</span>
                </div>
                <ul class="space-y-1.5 mb-4">
                  {exp.bullets.map((bullet) => (
                    <li class="flex items-start gap-2 text-sm text-gray-300 leading-relaxed">
                      <span class="w-1 h-1 rounded-full bg-indigo-500 flex-shrink-0 mt-2"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-2">
                  {exp.tags.map((tag) => (
                    <span class="text-xs px-2.5 py-1 rounded-lg bg-white/5 text-gray-300 border border-white/5">{tag}</span>
                  ))}
                </div>
              </article>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  {posts.length > 0 && (
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-end justify-between mb-16">
          <div>
            <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Blog</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-white">Derniers articles</h2>
          </div>
          <a href="/blog" class="text-sm text-gray-400 hover:text-indigo-400 transition-colors hidden sm:block">
            Voir tout →
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group bg-white/[0.03] border border-white/5 rounded-2xl p-6 hover:border-indigo-500/30 transition-all hover:-translate-y-1 flex flex-col"
            >
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="text-xs font-medium text-indigo-400 mb-3">{post.data.tags[0]}</span>
              )}
              <h3 class="text-base font-semibold text-white mb-2 group-hover:text-indigo-300 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-300 line-clamp-3 flex-1">{post.data.description}</p>
              <time class="text-xs text-gray-400 mt-4 pt-4 border-t border-white/5 block">
                {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
        <div class="text-center mt-8 sm:hidden">
          <a href="/blog" class="text-sm text-gray-400 hover:text-indigo-400 transition-colors">Voir tous les articles →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Contact -->
  <section id="contact" class="py-24 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Contact</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Démarrons une mission ensemble</h2>
      <p class="text-gray-400 mb-10 leading-relaxed">
        Besoin d'un CTO de transition, d'un architecte cloud sénior ou d'un regard expert sur votre SI ?
        Discutons-en.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="mailto:stephane@monfort.pro?subject=Prise%20de%20contact"
          class="inline-flex items-center gap-3 px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-xl transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Me contacter par mail
        </a>
        <a
          href="https://linkedin.com/in/smonfort"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-8 py-4 bg-white/5 hover:bg-white/10 text-white font-medium rounded-xl border border-white/10 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          Me contacter sur LinkedIn
        </a>
      </div>
    </div>
  </section>

<script>
  const text = 'Stéphane Monfort';
  const el = document.getElementById('typewriter');
  const cursor = document.getElementById('cursor');
  let i = 0;

  function type() {
    if (!el) return;
    if (i < text.length) {
      el.textContent += text[i++];
      setTimeout(type, 80);
    } else {
      cursor?.classList.add('blink');
    }
  }

  type();
</script>
</Layout>
