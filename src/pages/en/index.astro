---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/homepage/Hero.astro';
import About from '@components/homepage/About.astro';
import Skills from '@components/homepage/Skills.astro';
import Experience from '@components/homepage/Experience.astro';
import BlogPreview from '@components/homepage/BlogPreview.astro';
import Contact from '@components/homepage/Contact.astro';
import { useTranslations } from '@i18n/index';
import { getPersonSchema } from '@data/personSchema';

const t = useTranslations('en');
const personSchema = getPersonSchema(Astro.site!, 'en');
---

<Layout
  title={t.pages.home.title}
  description={t.pages.home.description}
  image="/images/og-default.png"
  lang="en"
>
  <Fragment slot="head" set:html={`<script type="application/ld+json">${personSchema}</script>`} />
  <Hero lang="en" />
  <About lang="en" />
  <Skills lang="en" />
  <Experience lang="en" />
  <BlogPreview lang="en" />
  <Contact lang="en" />
</Layout>
