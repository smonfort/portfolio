---
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import PostListItem from '@components/blog/PostListItem.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@i18n/index';

const t = useTranslations('en');

const posts = (await getCollection('blogEn', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredPosts = posts.slice(0, 2);
const remainingPosts = posts.slice(2);
---

<Layout
  title={t.pages.blog.title}
  description={t.pages.blog.description}
  image="/images/og-default.png"
  lang="en"
>
  <div class="mx-auto max-w-3xl px-6 py-20">
    <div class="mb-16">
      <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">
        {t.blog.label}
      </p>
      <h1 class="mb-4 text-4xl font-bold text-white sm:text-5xl">{t.blog.listHeading}</h1>
      <p class="text-lg text-gray-400">{t.blog.listDescription}</p>
    </div>

    {
      posts.length === 0 ? (
        <div class="py-20 text-center text-gray-500">
          <p>{t.blog.noArticles}</p>
        </div>
      ) : (
        <>
          <div class="mb-6 grid gap-6 sm:grid-cols-2">
            {featuredPosts.map((post) => (
              <PostCard
                href={`/en/blog/${post.data.slug ?? post.id}`}
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
                image={post.data.image}
                dateLocale={t.blog.dateLocale}
              />
            ))}
          </div>

          <div class="flex flex-col gap-3">
            {remainingPosts.map((post) => (
              <PostListItem
                href={`/en/blog/${post.data.slug ?? post.id}`}
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
                image={post.data.image}
                dateLocale={t.blog.dateLocale}
              />
            ))}
          </div>
        </>
      )
    }
  </div>
</Layout>
