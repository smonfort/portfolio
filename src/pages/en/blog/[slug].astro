---
import BlogLayout from '@layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '@utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blogEn', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, index) => ({
    params: { slug: post.data.slug ?? post.id },
    props: {
      post,
      prevPost: sorted[index + 1] ?? null,
      nextPost: sorted[index - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  image={post.data.image?.src}
  headings={headings}
  readingTime={readingTime}
  prevPost={prevPost
    ? { href: `/en/blog/${prevPost.data.slug ?? prevPost.id}`, title: prevPost.data.title }
    : undefined}
  nextPost={nextPost
    ? { href: `/en/blog/${nextPost.data.slug ?? nextPost.id}`, title: nextPost.data.title }
    : undefined}
  lang="en"
>
  <Content />
</BlogLayout>
