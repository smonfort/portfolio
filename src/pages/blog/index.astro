---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredPosts = posts.slice(0, 2);
const remainingPosts = posts.slice(2);
---

<Layout
  title="Blog — Cloud, Architecture & Leadership Tech | Stéphane Monfort"
  description="Retours d'expérience et réflexions sur le cloud AWS, l'architecture SI et le leadership technique."
>
  <div class="mx-auto max-w-3xl px-6 py-20">
    <div class="mb-16">
      <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">Blog</p>
      <h1 class="mb-4 text-4xl font-bold text-white sm:text-5xl">Tous les articles</h1>
      <p class="text-lg text-gray-400">
        Retours d'expérience, expérimentations et points de vue sur le cloud, l'architecture et le
        leadership tech.
      </p>
    </div>

    {
      posts.length === 0 ? (
        <div class="py-20 text-center text-gray-500">
          <p>Aucun article publié pour l'instant.</p>
        </div>
      ) : (
        <>
          <div class="mb-6 grid gap-6 sm:grid-cols-2">
            {featuredPosts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="group flex flex-col overflow-hidden rounded-xl border border-white/5 transition-colors hover:border-indigo-500/20"
              >
                {post.data.image ? (
                  (() => {
                    const img = post.data.image;
                    const isLandscape = img.width > img.height;
                    const processedHeight = isLandscape
                      ? 160
                      : Math.round((600 * img.height) / img.width);
                    return (
                      <div class="flex h-40 w-full items-center justify-center overflow-hidden bg-gray-950">
                        <Image
                          src={img}
                          alt={post.data.title}
                          width={600}
                          height={processedHeight}
                          class={`h-40 w-full ${isLandscape ? 'object-cover' : 'object-contain'}`}
                        />
                      </div>
                    );
                  })()
                ) : (
                  <img
                    src="/images/default-cover.svg"
                    alt={post.data.title}
                    class="h-40 w-full object-cover"
                  />
                )}
                <div class="flex flex-1 flex-col p-5">
                  <time class="mb-2 text-xs text-gray-400" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('fr-FR', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  <h2 class="mb-1 text-base font-semibold text-white transition-colors group-hover:text-indigo-300">
                    {post.data.title}
                  </h2>
                  <p class="line-clamp-2 flex-1 text-sm text-gray-300">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      {post.data.tags.map((tag) => (
                        <span class="rounded bg-indigo-500/10 px-2 py-0.5 text-xs text-indigo-400">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>

          <div class="flex flex-col gap-3">
            {remainingPosts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="group flex flex-row items-stretch overflow-hidden rounded-xl border border-white/5 transition-colors hover:border-indigo-500/20"
              >
                <div class="relative mr-4 w-28 shrink-0 overflow-hidden bg-gray-950">
                  {post.data.image ? (
                    (() => {
                      const img = post.data.image;
                      const isLandscape = img.width > img.height;
                      const processedHeight = isLandscape
                        ? 160
                        : Math.round((112 * img.height) / img.width);
                      return (
                        <Image
                          src={img}
                          alt={post.data.title}
                          width={112}
                          height={processedHeight}
                          class={`absolute inset-0 h-full w-full ${isLandscape ? 'object-cover' : 'object-contain'}`}
                        />
                      );
                    })()
                  ) : (
                    <img
                      src="/images/default-cover.svg"
                      alt={post.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  )}
                </div>
                <div class="flex min-w-0 flex-1 flex-col justify-center py-3 pr-5">
                  <h2 class="mb-1 truncate text-sm font-semibold text-white transition-colors group-hover:text-indigo-300">
                    {post.data.title}
                  </h2>
                  <p class="mb-2 line-clamp-1 text-xs text-gray-300">{post.data.description}</p>
                  <time class="mb-2 text-xs text-gray-400" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('fr-FR', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {post.data.tags.map((tag) => (
                        <span class="rounded bg-indigo-500/10 px-2 py-0.5 text-xs text-indigo-400">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </>
      )
    }
  </div>
</Layout>
