---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<Layout title="Blog — Articles & Réflexions" description="Articles techniques, retours d'expérience et réflexions sur le développement web.">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <div class="mb-16">
      <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Blog</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Tous les articles</h1>
      <p class="text-gray-400 text-lg">Retours d'expérience, expérimentations et points de vue sur le cloud, l'architecture et le leadership tech.</p>
    </div>

{posts.length === 0 ? (
      <div class="text-center py-20 text-gray-500">
        <p>Aucun article publié pour l'instant.</p>
      </div>
    ) : (
      <div class="space-y-px">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col sm:flex-row sm:items-start gap-4 py-6 border-b border-white/5 hover:border-indigo-500/20 transition-colors"
          >
            <time class="text-sm text-gray-600 sm:w-32 flex-shrink-0 pt-0.5">
              {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <div class="flex-1 min-w-0">
              <h2 class="text-base font-semibold text-white group-hover:text-indigo-300 transition-colors mb-1">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {post.data.tags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded bg-indigo-500/10 text-indigo-400">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <svg class="w-4 h-4 text-gray-600 group-hover:text-indigo-400 transition-colors flex-shrink-0 mt-0.5 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
