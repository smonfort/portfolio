---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

---

<Layout title="Blog — Articles & Réflexions" description="Articles techniques, retours d'expérience et réflexions sur le développement web.">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <div class="mb-16">
      <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-4">Blog</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Tous les articles</h1>
      <p class="text-gray-400 text-lg">Retours d'expérience, expérimentations et points de vue sur le cloud, l'architecture et le leadership tech.</p>
    </div>

{posts.length === 0 ? (
      <div class="text-center py-20 text-gray-500">
        <p>Aucun article publié pour l'instant.</p>
      </div>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col rounded-xl border border-white/5 overflow-hidden hover:border-indigo-500/20 transition-colors"
          >
            {post.data.image ? (
              <Image
                src={post.data.image}
                alt={post.data.title}
                width={600}
                height={160}
                class="w-full h-40 object-cover"
              />
            ) : (
              <img
                src="/images/default-cover.svg"
                alt={post.data.title}
                class="w-full h-40 object-cover"
              />
            )}
            <div class="flex flex-col flex-1 p-5">
              <time class="text-xs text-gray-600 mb-2">
                {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <h2 class="text-base font-semibold text-white group-hover:text-indigo-300 transition-colors mb-1">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 line-clamp-2 flex-1">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {post.data.tags.map((tag) => (
                    <span class="text-xs px-2 py-0.5 rounded bg-indigo-500/10 text-indigo-400">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
