---
import Layout from '@layouts/Layout.astro';
import TableOfContents from '@components/TableOfContents.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  image?: string;
  headings?: { depth: number; slug: string; text: string }[];
  readingTime?: number;
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  image,
  headings = [],
  readingTime,
  prevPost,
  nextPost,
} = Astro.props;
const siteUrl = Astro.site!;
const personId = new URL('#person', siteUrl).toString();
const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const linkedInShareUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(title)}&summary=${encodeURIComponent(description ?? '')}`;
const twitterShareUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(title)}`;

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Accueil',
      item: siteUrl.href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: new URL('/blog/', siteUrl).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: pageUrl,
    },
  ],
});

const blogPostingSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  dateModified: (updatedDate ?? date).toISOString(),
  url: pageUrl,
  inLanguage: 'fr-FR',
  author: {
    '@type': 'Person',
    '@id': personId,
    name: 'Stéphane Monfort',
    url: siteUrl.href,
  },
  publisher: {
    '@type': 'Person',
    '@id': personId,
    name: 'Stéphane Monfort',
  },
  ...(image && { image: new URL(image, siteUrl).toString() }),
});
---

<Layout
  title={`${title} | Stéphane Monfort`}
  description={description}
  image={image}
  ogType="article"
>
  <Fragment
    slot="head"
    set:html={`<script type="application/ld+json">${blogPostingSchema}</script><script type="application/ld+json">${breadcrumbSchema}</script>`}
  />
  <div class="mx-auto max-w-screen-xl px-6 py-20">
    <div
      class="xl:grid xl:grid-cols-[minmax(0,_48rem)_18rem] xl:items-start xl:justify-center xl:gap-12"
    >
      <article class="mx-auto w-full max-w-3xl xl:mx-0">
        <a
          href="/blog"
          class="group mb-10 inline-flex items-center gap-2 text-sm font-semibold text-gray-300 transition-colors hover:text-indigo-400"
        >
          <svg
            class="h-4 w-4 transition-transform group-hover:-translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Voir tous les articles
        </a>

        <header class="mb-12">
          <h1 class="mb-4 text-4xl leading-tight font-bold text-white sm:text-5xl">{title}</h1>
          {description && <p class="mb-4 text-lg text-gray-400">{description}</p>}
          {
            tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="rounded-full border border-indigo-500/20 bg-indigo-500/10 px-3 py-1 text-xs font-medium text-indigo-400">
                    {tag}
                  </span>
                ))}
              </div>
            )
          }
          <div
            class="mt-6 mb-8 flex flex-col gap-3 border-b border-white/5 pb-6 sm:flex-row sm:items-center sm:justify-between"
          >
            <div class="flex items-center gap-3 text-sm text-gray-400">
              <time datetime={date.toISOString()}>{formattedDate}</time>
              <span aria-hidden="true">·</span>
              <span>Stéphane Monfort</span>
              {
                readingTime && (
                  <>
                    <span aria-hidden="true" class="hidden sm:inline">
                      ·
                    </span>
                    <span class="hidden sm:inline">{readingTime} min de lecture</span>
                  </>
                )
              }
            </div>
            <div class="flex items-center justify-between sm:justify-normal sm:gap-2">
              {
                readingTime && (
                  <span class="text-sm text-gray-400 sm:hidden">{readingTime} min de lecture</span>
                )
              }
              <div class="flex items-center gap-2">
                <span class="text-sm text-gray-400">Partager</span>
                <a
                  href={linkedInShareUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Partager "${title}" sur LinkedIn (ouvre dans un nouvel onglet)`}
                  class="inline-flex items-center justify-center rounded-md border border-white/10 bg-white/5 p-2 text-gray-400 transition-colors hover:border-indigo-500/30 hover:bg-indigo-500/5 hover:text-indigo-400"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                    ></path>
                  </svg>
                </a>
                <a
                  href={twitterShareUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Partager "${title}" sur X/Twitter (ouvre dans un nouvel onglet)`}
                  class="inline-flex items-center justify-center rounded-md border border-white/10 bg-white/5 p-2 text-gray-400 transition-colors hover:border-indigo-500/30 hover:bg-indigo-500/5 hover:text-indigo-400"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
                    ></path>
                  </svg>
                </a>
                <div aria-live="polite" aria-atomic="true" class="sr-only" id="copy-feedback"></div>
                <button
                  data-copy-url={pageUrl}
                  aria-label="Copier le lien de l'article"
                  class="inline-flex items-center justify-center rounded-md border border-white/10 bg-white/5 p-2 text-gray-400 transition-colors hover:border-indigo-500/30 hover:bg-indigo-500/5 hover:text-indigo-400"
                >
                  <svg
                    class="copy-icon h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                    ></path>
                  </svg>
                  <svg
                    class="check-icon hidden h-4 w-4 text-green-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </button>
              </div>
              <script is:inline>
                document.querySelectorAll('button[data-copy-url]').forEach((btn) => {
                  btn.addEventListener('click', async () => {
                    const url = btn.getAttribute('data-copy-url');
                    await navigator.clipboard.writeText(url);
                    const copyIcon = btn.querySelector('.copy-icon');
                    const checkIcon = btn.querySelector('.check-icon');
                    const feedback = document.getElementById('copy-feedback');
                    copyIcon.classList.add('hidden');
                    checkIcon.classList.remove('hidden');
                    if (feedback) feedback.textContent = 'Lien copié dans le presse-papiers';
                    setTimeout(() => {
                      copyIcon.classList.remove('hidden');
                      checkIcon.classList.add('hidden');
                      if (feedback) feedback.textContent = '';
                    }, 2000);
                  });
                });
              </script>
            </div>
          </div>

          <div class="prose-custom">
            <slot />
          </div>

          {
            (prevPost || nextPost) && (
              <nav aria-label="Navigation entre articles" class="mt-12">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                  {prevPost ? (
                    <a
                      href={`/blog/${prevPost.slug}`}
                      class="group flex flex-col gap-1 rounded-lg border border-white/10 bg-white/5 p-4 transition-colors hover:border-indigo-500/30 hover:bg-indigo-500/5"
                    >
                      <span class="flex items-center gap-1 text-xs text-gray-500">
                        <svg
                          class="h-3.5 w-3.5 transition-transform group-hover:-translate-x-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"
                          />
                        </svg>
                        Article précédent
                      </span>
                      <span class="line-clamp-2 text-sm font-medium text-gray-200 transition-colors group-hover:text-indigo-400">
                        {prevPost.title}
                      </span>
                    </a>
                  ) : (
                    <div />
                  )}
                  {nextPost && (
                    <a
                      href={`/blog/${nextPost.slug}`}
                      class="group flex flex-col gap-1 rounded-lg border border-white/10 bg-white/5 p-4 text-right transition-colors hover:border-indigo-500/30 hover:bg-indigo-500/5 sm:items-end"
                    >
                      <span class="flex items-center justify-end gap-1 text-xs text-gray-500">
                        Article suivant
                        <svg
                          class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                          />
                        </svg>
                      </span>
                      <span class="line-clamp-2 text-sm font-medium text-gray-200 transition-colors group-hover:text-indigo-400">
                        {nextPost.title}
                      </span>
                    </a>
                  )}
                </div>
              </nav>
            )
          }

          <section aria-label="Commentaires" class="mt-8" style="min-height: 150px">
            <h2 class="sr-only">Commentaires</h2>
            <script is:inline>
              const s = document.createElement('script');
              s.src = 'https://utteranc.es/client.js';
              s.setAttribute('repo', 'smonfort/portfolio');
              s.setAttribute('issue-term', 'pathname');
              s.setAttribute('theme', 'github-dark');
              s.setAttribute('crossorigin', 'anonymous');
              s.async = true;
              document.currentScript.parentElement.appendChild(s);
            </script>
          </section>
        </header>
      </article>

      <aside class="sticky top-40 hidden w-72 shrink-0 self-start xl:block">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>
</Layout>
