---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  image?: string;
}

const { title, description, date, tags = [], image } = Astro.props;
const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://www.monfort.pro').toString();
const linkedInShareUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(title)}&summary=${encodeURIComponent(description ?? '')}`;

const blogPostingSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  url: pageUrl,
  inLanguage: 'fr-FR',
  author: {
    '@type': 'Person',
    '@id': 'https://www.monfort.pro/#person',
    name: 'Stéphane Monfort',
    url: 'https://www.monfort.pro',
  },
  publisher: {
    '@type': 'Person',
    '@id': 'https://www.monfort.pro/#person',
    name: 'Stéphane Monfort',
  },
  ...(image && { image: new URL(image, Astro.site ?? 'https://www.monfort.pro').toString() }),
});
---

<Layout
  title={`${title} | Stéphane Monfort`}
  description={description}
  image={image}
  ogType="article"
>
  <Fragment
    slot="head"
    set:html={`<script type="application/ld+json">${blogPostingSchema}</script>`}
  />
  <article class="max-w-3xl mx-auto px-6 py-20">
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm font-semibold text-gray-300 hover:text-indigo-400 transition-colors mb-10 group"
    >
      <svg
        class="w-4 h-4 transition-transform group-hover:-translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
      Voir tous les articles
    </a>

    <header class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">{title}</h1>
      {description && <p class="text-lg text-gray-400 mb-4">{description}</p>}
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-xs font-medium px-3 py-1 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <div class="mt-6 pt-6 border-t border-white/5 flex items-center justify-between gap-4">
        <time class="text-sm text-gray-300" datetime={date.toISOString()}>{formattedDate}</time>
        <a
          href={linkedInShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md overflow-hidden bg-[#0a66c2] hover:bg-[#004182] transition-colors"
        >
          <span class="flex items-center justify-center px-3 py-2 border-r border-[#004182]/40">
            <svg class="w-5 h-5" fill="white" viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </span>
          <span class="px-4 py-2 text-sm font-bold text-white uppercase tracking-wide"
            >Partager</span
          >
        </a>
      </div>
    </header>

    <div class="prose-custom">
      <slot />
    </div>

    <div class="mt-16 pt-10 border-t border-white/5">
      <script
        src="https://utteranc.es/client.js"
        repo="smonfort/portfolio"
        issue-term="pathname"
        theme="github-dark"
        crossorigin="anonymous"
        async></script>
    </div>
  </article>
</Layout>
