---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Stéphane Monfort — CTO & Architecte Cloud Senior freelance, certifié AWS et TOGAF.',
} = Astro.props;

const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Stéphane Monfort',
  jobTitle: 'CTO & Architecte Cloud Senior Freelance',
  url: 'https://www.monfort.pro',
  email: 'stephane@monfort.pro',
  sameAs: ['https://linkedin.com/in/smonfort'],
  knowsAbout: [
    'Cloud Architecture',
    'AWS',
    'Kubernetes',
    'Tech Leadership',
    'DevOps',
    'Software Architecture',
  ],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'AWS Certified Solutions Architect – Associate',
      credentialCategory: 'Professional Certification',
      recognizedBy: { '@type': 'Organization', name: 'Amazon Web Services' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'TOGAF 9.1 Expert',
      credentialCategory: 'Professional Certification',
      recognizedBy: { '@type': 'Organization', name: 'The Open Group' },
    },
  ],
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'École Centrale de Lyon',
  },
});
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title}</title>
    <script type="application/ld+json" set:html={personSchema} />
    <Analytics />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
