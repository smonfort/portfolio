---
const navLinks = [
  { href: '/#about', label: 'À propos' },
  { href: '/#skills', label: 'Expertises' },
  { href: '/#experience', label: 'Références' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 right-0 left-0 z-50 border-b border-white/5 bg-black/60 backdrop-blur-xl"
>
  <nav
    aria-label="Navigation principale"
    class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6"
  >
    <a
      href="/"
      class="text-lg font-bold tracking-tight text-white transition-colors hover:text-indigo-400"
    >
      <span class="text-gradient">Stéphane Monfort</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-colors',
                currentPath === href ? 'text-indigo-400' : 'text-gray-400 hover:text-white',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="text-gray-400 transition-colors hover:text-white md:hidden"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="icon-open"
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="icon-close"
        class="hidden h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="absolute top-full right-0 left-0 hidden border-t border-white/5 bg-black/90 backdrop-blur-xl md:hidden"
    >
      <ul class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-4">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="block py-1 text-sm font-medium text-gray-400 transition-colors hover:text-white"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    btn.setAttribute('aria-label', isExpanded ? 'Ouvrir le menu' : 'Fermer le menu');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  const closeMenu = () => {
    btn?.setAttribute('aria-expanded', 'false');
    btn?.setAttribute('aria-label', 'Ouvrir le menu');
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  };

  // Close menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      btn?.focus();
    }
  });
</script>
