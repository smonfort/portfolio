---
import { useTranslations, getNavLinks, getAltLang, getAltLangPath } from '@i18n/index';
import type { Lang } from '@i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const navLinks = getNavLinks(lang);
const homeHref = lang === 'en' ? '/en/' : '/';
const currentPath = Astro.url.pathname;
const altLang = getAltLang(lang);
const altLangPath = getAltLangPath(lang, currentPath);
---

<header
  class="fixed top-0 right-0 left-0 z-50 border-b border-white/5 bg-black/60 backdrop-blur-xl"
>
  <nav
    aria-label={t.nav.ariaLabel}
    class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6"
  >
    <a
      href={homeHref}
      class="text-lg font-bold tracking-tight text-white transition-colors hover:text-indigo-400"
    >
      <span class="text-gradient">Stéphane Monfort</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-colors',
                currentPath === href ? 'text-indigo-400' : 'text-gray-400 hover:text-white',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Language switcher (desktop) -->
    <a
      href={altLangPath}
      hreflang={altLang}
      aria-label={t.nav.switchLang}
      class="hidden items-center gap-1.5 rounded-md border border-white/10 px-2.5 py-1 text-xs font-semibold tracking-wider text-gray-400 transition-colors hover:border-indigo-500/30 hover:text-white md:flex"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
        ></path>
      </svg>
      {altLang.toUpperCase()}
    </a>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="text-gray-400 transition-colors hover:text-white md:hidden"
      aria-label={t.nav.openMenu}
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-label-open={t.nav.openMenu}
      data-label-close={t.nav.closeMenu}
    >
      <svg
        id="icon-open"
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="icon-close"
        class="hidden h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="absolute top-full right-0 left-0 hidden border-t border-white/5 bg-black/90 backdrop-blur-xl md:hidden"
    >
      <ul class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-4">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="block py-1 text-sm font-medium text-gray-400 transition-colors hover:text-white"
              >
                {label}
              </a>
            </li>
          ))
        }
        <li class="border-t border-white/5 pt-3">
          <a
            href={altLangPath}
            hreflang={altLang}
            aria-label={t.nav.switchLang}
            class="flex items-center gap-2 py-1 text-sm font-medium text-gray-400 transition-colors hover:text-white"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
              ></path>
            </svg>
            {t.nav.switchLang}
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const labelOpen = btn?.dataset.labelOpen ?? '';
  const labelClose = btn?.dataset.labelClose ?? '';

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    btn.setAttribute('aria-label', isExpanded ? labelOpen : labelClose);
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  const closeMenu = () => {
    btn?.setAttribute('aria-expanded', 'false');
    btn?.setAttribute('aria-label', labelOpen);
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  };

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      btn?.focus();
    }
  });
</script>
