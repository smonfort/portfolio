---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  image?: ImageMetadata;
  headingLevel?: 'h2' | 'h3';
  dateLocale?: string;
}

const {
  href,
  title,
  description,
  date,
  tags,
  image,
  headingLevel = 'h2',
  dateLocale = 'fr-FR',
} = Astro.props;

const Tag = headingLevel;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-xl border border-white/5 transition-colors hover:border-indigo-500/20"
>
  {
    image ? (
      (() => {
        const isLandscape = image.width > image.height;
        const processedHeight = isLandscape ? 160 : Math.round((600 * image.height) / image.width);
        return (
          <div class="flex h-40 w-full items-center justify-center overflow-hidden bg-gray-950">
            <Image
              src={image}
              alt={title}
              width={600}
              height={processedHeight}
              loading="lazy"
              class={`h-40 w-full ${isLandscape ? 'object-cover' : 'object-contain'}`}
            />
          </div>
        );
      })()
    ) : (
      <img
        src="/images/default-cover.svg"
        alt={title}
        width="600"
        height="160"
        class="h-40 w-full object-cover"
        loading="lazy"
      />
    )
  }
  <div class="flex flex-1 flex-col p-5">
    <time class="mb-2 text-xs text-gray-400" datetime={date.toISOString()}>
      {date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
    <Tag
      class="mb-1 text-base font-semibold text-white transition-colors group-hover:text-indigo-300"
    >
      {title}
    </Tag>
    <p class="line-clamp-2 flex-1 text-sm text-gray-300">{description}</p>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="rounded bg-indigo-500/10 px-2 py-0.5 text-xs text-indigo-400">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>
