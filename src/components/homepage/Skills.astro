---
import { useTranslations } from '@i18n/index';
import type { Lang } from '@i18n/index';
import { expertisesData, certificationsData } from '@data/expertises';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
---

<section id="skills" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">
        {t.skills.label}
      </p>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.skills.heading}</h2>
    </div>
    <div class="divide-y divide-white/5">
      {
        expertisesData.map(({ label: categoryLabel, categorySvg, items }) => (
          <div class="grid items-start gap-6 py-8 md:grid-cols-4">
            <h3 class="flex justify-center self-center text-center text-lg font-semibold tracking-wider text-indigo-400 uppercase md:justify-end md:text-right">
              <span class="inline-flex items-center gap-2">
                {categorySvg && (
                  <svg
                    class="h-4 w-4 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    set:html={categorySvg}
                  />
                )}
                {categoryLabel}
              </span>
            </h3>
            <div class="flex flex-wrap gap-2 md:col-span-3">
              {items.map((item) => (
                <span class="inline-flex items-center gap-1.5 rounded-lg border border-white/5 bg-white/5 px-2.5 py-1.5 text-xs text-gray-300">
                  {item.icon && (
                    <img
                      src={`https://cdn.simpleicons.org/${item.icon}`}
                      alt={item.label}
                      class="h-3.5 w-3.5 flex-shrink-0"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  )}
                  {item.iconUrl && (
                    <img
                      src={item.iconUrl}
                      alt={item.label}
                      class="h-3.5 w-3.5 flex-shrink-0"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  )}
                  {item.svg && (
                    <svg
                      class="h-3.5 w-3.5 flex-shrink-0 text-indigo-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      set:html={item.svg}
                    />
                  )}
                  {!item.icon && !item.iconUrl && !item.svg && (
                    <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-indigo-500" />
                  )}
                  {item.label}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Certifications -->
    <div class="mt-20 mb-16 text-center">
      <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">
        {t.skills.certLabel}
      </p>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.skills.certHeading}</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        certificationsData.map(({ name, iconUrl, link }) => {
          return link ? (
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${name} ${t.skills.certAriaOpen}`}
              class="group flex items-center gap-4 rounded-2xl border border-white/5 bg-white/[0.03] p-5 transition-colors hover:border-amber-500/30"
            >
              <img
                src={iconUrl}
                alt={name}
                width="28"
                height="28"
                class="h-7 w-7 flex-shrink-0"
                loading="lazy"
              />
              <div class="flex-1">
                <p class="text-sm font-semibold text-white transition-colors group-hover:text-amber-400">
                  {name}
                </p>
              </div>
              <svg
                class="h-4 w-4 text-gray-600 transition-colors group-hover:text-amber-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          ) : (
            <div class="flex items-center gap-4 rounded-2xl border border-white/5 bg-white/[0.03] p-5 transition-colors hover:border-indigo-500/30">
              <img
                src={iconUrl}
                alt={name}
                width="28"
                height="28"
                class="h-7 w-7 flex-shrink-0"
                loading="lazy"
              />
              <div>
                <p class="text-sm font-semibold text-white">{name}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
