---
import { useTranslations } from '@i18n/index';
import type { Lang } from '@i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <div class="grid items-start gap-16 md:grid-cols-2">
      <div>
        <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">
          {t.about.label}
        </p>
        <h2 class="mb-8 text-3xl leading-tight font-bold text-white sm:text-4xl">
          {t.about.heading}
        </h2>
        <div class="space-y-5 leading-relaxed text-gray-400">
          <p>{t.about.p1}</p>
          <p set:html={t.about.p2Html} />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 md:pt-16">
        {
          t.about.stats.map(({ value, emoji, label }) => (
            <div class="rounded-2xl border border-white/5 bg-white/[0.03] p-6 text-center transition-colors hover:border-indigo-500/20">
              <div class="mb-1 text-2xl font-bold text-indigo-400">{value}</div>
              <div class="text-sm text-gray-300">
                {label} <span aria-hidden="true">{emoji}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
