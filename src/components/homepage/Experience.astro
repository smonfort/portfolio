---
import { useTranslations } from '@i18n/index';
import type { Lang } from '@i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const { items: experiences, label, heading } = t.experience;
---

<section id="experience" class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">{label}</p>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">{heading}</h2>
    </div>
    <div class="relative">
      <!-- Timeline line -->
      <div
        class="absolute top-0 bottom-0 left-0 hidden w-px -translate-x-px bg-white/5 md:left-1/2 md:block"
      >
      </div>

      <div class="space-y-8">
        {
          experiences.map((exp, i) => (
            <div
              class:list={[
                'group relative items-start gap-8 md:grid md:grid-cols-2',
                i % 2 === 0 ? '' : 'md:[&>article]:col-start-2',
              ]}
            >
              <div class="absolute top-6 left-1/2 z-10 hidden h-3 w-3 -translate-x-1.5 rounded-full border-2 border-indigo-900 bg-indigo-500 transition-transform group-hover:scale-125 md:block" />

              <article
                class:list={[
                  'rounded-2xl border border-white/5 bg-white/[0.03] p-6 transition-colors hover:border-indigo-500/30',
                  i % 2 !== 0 ? 'md:col-start-2' : '',
                ]}
              >
                <div class="mb-3 flex items-start justify-between gap-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center">
                      <img
                        src={exp.logo}
                        alt={exp.company}
                        width="32"
                        height="32"
                        class="h-8 w-8 object-contain"
                        loading="lazy"
                      />
                    </div>
                    <div>
                      <h3 class="text-base font-semibold text-white">{exp.title}</h3>
                      <p class="text-sm text-indigo-400">{exp.company}</p>
                    </div>
                  </div>
                  <span class="text-xs whitespace-nowrap text-gray-400">{exp.period}</span>
                </div>
                <ul class="mb-4 space-y-1.5">
                  {exp.bullets.map((bullet) => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed text-gray-300">
                      <span class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-indigo-500" />
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-2">
                  {exp.tags.map((tag) => (
                    <span class="rounded-lg border border-white/5 bg-white/5 px-2.5 py-1 text-xs text-gray-300">
                      {tag}
                    </span>
                  ))}
                </div>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
