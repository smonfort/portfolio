---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

{
  posts.length > 0 && (
    <section class="px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="mb-16 flex items-end justify-between">
          <div>
            <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">Blog</p>
            <h2 class="text-3xl font-bold text-white sm:text-4xl">Derniers articles</h2>
          </div>
          <a
            href="/blog"
            class="hidden text-sm text-gray-400 transition-colors hover:text-indigo-400 sm:block"
          >
            Voir tout →
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col overflow-hidden rounded-xl border border-white/5 transition-colors hover:border-indigo-500/20"
            >
              {post.data.image ? (
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  width={600}
                  height={160}
                  class="h-40 w-full object-cover"
                />
              ) : (
                <img
                  src="/images/default-cover.svg"
                  alt={post.data.title}
                  width="600"
                  height="160"
                  class="h-40 w-full object-cover"
                />
              )}
              <div class="flex flex-1 flex-col p-5">
                <time class="mb-2 text-xs text-gray-400" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('fr-FR', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                <h3 class="mb-1 text-base font-semibold text-white transition-colors group-hover:text-indigo-300">
                  {post.data.title}
                </h3>
                <p class="line-clamp-2 flex-1 text-sm text-gray-300">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {post.data.tags.map((tag) => (
                      <span class="rounded bg-indigo-500/10 px-2 py-0.5 text-xs text-indigo-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
        <div class="mt-8 text-center sm:hidden">
          <a href="/blog" class="text-sm text-gray-400 transition-colors hover:text-indigo-400">
            Voir tous les articles →
          </a>
        </div>
      </div>
    </section>
  )
}
