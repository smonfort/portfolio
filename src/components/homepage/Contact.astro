<section id="contact" class="px-6 py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="mb-4 text-xs font-semibold tracking-widest text-indigo-400 uppercase">Contact</p>
    <h2 class="mb-6 text-3xl font-bold text-white sm:text-4xl">Démarrons une mission ensemble</h2>
    <p class="mb-10 leading-relaxed text-gray-400">
      Besoin d'un CTO de transition, d'un architecte cloud sénior ou d'un regard expert sur votre SI
      ? Discutons-en.
    </p>
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="mailto:stephane@monfort.pro?subject=Prise%20de%20contact"
        class="inline-flex items-center gap-3 rounded-xl bg-indigo-600 px-8 py-4 font-medium text-white transition-colors hover:bg-indigo-500"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        Me contacter par mail
      </a>
      <a
        href="https://linkedin.com/in/smonfort"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-8 py-4 font-medium text-white transition-colors hover:bg-white/10"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
        Me contacter sur LinkedIn
      </a>
    </div>
  </div>
</section>
